{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build proj with OpenMP",
      "type": "shell",
      "command": "clang",
      "args": [
        "-Xpreprocessor",
        "-fopenmp",
        "-I/opt/homebrew/opt/libomp/include",
        "-L/opt/homebrew/opt/libomp/lib",
        "-lomp",
        "-o",
        "proj",
        "proj.c"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
